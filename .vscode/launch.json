{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "BirdParadiseMCPServer (module)",
      "type": "python",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "request": "launch",
      "module": "mcp_server.bird_paradise_server",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ]
}
